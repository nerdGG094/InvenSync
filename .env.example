# === Modelo de configuração — copie para .env e preencha com valores reais ===
# cp .env.example .env   (ou copie manualmente no Windows)

# Flask — gere uma chave com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-por-uma-chave-secreta

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=inventario_almox
DB_USER=postgres
DB_PASSWORD=sua-senha-do-postgres

# Alternativa: URL completa (sobrescreve as variáveis DB_* acima)
# DATABASE_URL=postgresql+psycopg://usuario:senha@host:5432/inventario_almox

# === WhatsApp via CallMeBot (gratuito) — opcional ===
# Cada destino precisa de uma apikey própria do CallMeBot:
#   1) No WhatsApp do destino, envie "I allow callmebot to send me messages"
#      para o número +34 644 51 95 23.
#   2) O CallMeBot responde com a apikey daquele número.
# Ligue com WHATSAPP_ENABLED=1 e liste os destinos da TI como numero:apikey,
# separados por vírgula.
WHATSAPP_ENABLED=0
CALLMEBOT_RECIPIENTS=5544999999999:123456,5544988888888:654321

# === Backup do banco (pg_dump) — opcional ===
# Pasta de destino e quantos backups manter (rotação). PG_DUMP só é necessário
# se o pg_dump.exe não estiver no caminho padrão do PostgreSQL.
BACKUP_DIR=
BACKUP_KEEP=30
# PG_DUMP=C:\Program Files\PostgreSQL\17\bin\pg_dump.exe

# === Alertas proativos (estoque/licenças/chamados) ===
ALERTS_ENABLED=1
ALERTS_TICKET_STUCK_HOURS=48
ALERTS_LICENSE_DAYS=30
# Digest por WhatsApp: horas do dia (no máx. 1 envio por janela). Ex.: cedo e ~17h.
ALERTS_WHATSAPP_HOURS=8,17
# De quanto em quanto tempo (min) o agendador acorda para checar.
ALERTS_CHECK_MINUTES=30

# === Sessão / segurança ===
# Logout automático por inatividade (minutos). 0 = desligado.
INACTIVITY_MINUTES=0
# Ligue ambos APENAS ao servir por HTTPS atrás de proxy reverso (veja docs/HTTPS.md).
# BEHIND_PROXY=1
# SESSION_COOKIE_SECURE=1
